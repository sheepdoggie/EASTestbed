{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/experiment.schema.json",
  "title": "EAS Testbed Experiment Manifest",
  "type": "object",
  "required": ["schema_version", "experiment_id", "experiment_class", "motif", "field_family", "kernel_rule", "templates", "invariants", "redescription", "outputs"],
  "properties": {
    "schema_version": {"type": "string"},
    "experiment_id": {"type": "string"},
    "title": {"type": "string"},
    "experiment_class": {"type": "string", "enum": ["exploratory", "heuristic", "evidential"]},
    "motif": {
      "type": "object",
      "required": ["motif_ref"],
      "properties": {
        "motif_ref": {"type": "string"},
        "variation_mode": {"type": "string", "enum": ["none", "perturbation", "family_scan", "falsification", "comparison"]},
        "overrides": {"type": "object", "additionalProperties": true}
      },
      "additionalProperties": false
    },
    "field_family": {
      "type": "object",
      "required": ["field_ref"],
      "properties": {
        "field_ref": {"type": "string"},
        "overrides": {"type": "object", "additionalProperties": true}
      },
      "additionalProperties": false
    },
    "kernel_rule": {
      "type": "object",
      "required": ["rule_ref"],
      "properties": {
        "rule_ref": {"type": "string"},
        "overrides": {"type": "object", "additionalProperties": true}
      },
      "additionalProperties": false
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "redescription": {
      "type": "object",
      "required": ["engine_ref"],
      "properties": {
        "engine_ref": {"type": "string"},
        "orbit_size": {"type": "integer", "minimum": 0},
        "seed": {"type": ["integer", "null"]}
      },
      "additionalProperties": false
    },
    "interface": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "emulator_ref": {"type": "string"},
        "calibration_ref": {"type": "string"}
      },
      "additionalProperties": false
    },
    "outputs": {
      "type": "object",
      "required": ["report_ref", "artifact_dir"],
      "properties": {
        "report_ref": {"type": "string"},
        "artifact_dir": {"type": "string"},
        "write_registry": {"type": "boolean"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
