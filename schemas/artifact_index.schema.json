{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/artifact_index.schema.json",
  "title": "EAS Testbed Artifact Index",
  "type": "object",
  "required": ["index_version", "experiment_id", "created_at_utc", "artifacts"],
  "properties": {
    "index_version": {"type": "string"},
    "experiment_id": {"type": "string"},
    "created_at_utc": {"type": "string"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "path", "role"],
        "properties": {
          "kind": {"type": "string"},
          "path": {"type": "string"},
          "role": {"type": "string"},
          "sha256": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{64}$"
          },
          "media_type": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
