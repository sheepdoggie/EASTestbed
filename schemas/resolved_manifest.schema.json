{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/resolved_manifest.schema.json",
  "title": "EAS Testbed Resolved Manifest",
  "type": "object",
  "required": [
    "record_version",
    "experiment_id",
    "title",
    "experiment_class",
    "schema_version",
    "schema_path",
    "manifest_path",
    "resolved_at_utc",
    "repo_root",
    "manifest"
  ],
  "properties": {
    "record_version": {"type": "string"},
    "experiment_id": {"type": "string"},
    "title": {"type": "string"},
    "experiment_class": {
      "type": "string",
      "enum": ["exploratory", "heuristic", "evidential"]
    },
    "schema_version": {"type": ["string", "null"]},
    "schema_path": {"type": "string"},
    "manifest_path": {"type": "string"},
    "resolved_at_utc": {"type": "string"},
    "repo_root": {"type": "string"},
    "manifest": {"type": "object"}
  },
  "additionalProperties": false
}
